// Vehicle Architecture in SysML v2
@SysML
package 'Vehicle Model' {
    import ScalarValues::*;
    import SequenceFunctions::*;

    doc
    /*
     * This is a multi-line comment.
     * /* It can be nested! */
     */

    part def Vehicle {
        attribute mass: Real;
        attribute isElectric: Boolean = true;

        port powerIn;
        port powerOut;
        
        part engine: Engine[1];
        part wheels: Wheel[4];
        part spareWheels: Wheel[0..*];

        connection power_connection connect engine.out to wheels.in;
    }

    part def Engine {
        out port 'out';
        perform action generatePower {
            in fuel: Real;
            out power: Real;
            
            if (fuel > 0.0 and not self.isBroken) {
                power = fuel * 0.8;
            } else {
                power = 0.0;
            }
        }
    }

    part def Wheel {
        in port 'in';
    }

    requirement def 'Top Speed Requirement' {
        doc /* The vehicle shall be capable of a top speed of 120 mph. */
        attribute expectedSpeed = 120.0;
        subject vehicle: Vehicle;
        
        require constraint {
            vehicle.mass > 0 implies expectedSpeed > 0
        }
    }
}