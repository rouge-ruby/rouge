import "pe"

rule ExampleRule : demo
{
    meta:
        author = "Rouge"
        score = 75
        is_demo = true

    strings:
        $text = "malware" ascii wide nocase
        $hex = { 4D 5A 90 00 ?? [4-8] 50 45 }
